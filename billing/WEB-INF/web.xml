<web-app>
	<display-name>HIS</display-name>
    <description>
      Hospital Information system.
    </description>

    <!-- HTTPS Enforcement Filter - Fixes Mixed Content errors when behind HTTPS reverse proxy -->
    <filter>
        <filter-name>HttpsEnforcementFilter</filter-name>
        <filter-class>util.HttpsEnforcementFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>HttpsEnforcementFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

 <resource-ref>
      <description>DB Connection</description>
      <res-ref-name>jdbc/dehsdb</res-ref-name>
      <res-type>javax.sql.DataSource</res-type>
      <res-auth>Container</res-auth>
    </resource-ref>
<servlet>
    <servlet-name>BillingServerServlet</servlet-name>
    <servlet-class>servers.BillingServerServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
</servlet>

<servlet-mapping>
    <servlet-name>BillingServerServlet</servlet-name>
    <url-pattern>/BillingServer</url-pattern>
</servlet-mapping>

